# ── Frontend test environment variables ──────────────────────────────────────
# Copy this file to .env.test and fill in values for integration testing.
# For unit tests with MSW, most of these are not required.

# API base URL (used by api.js and AuthContext)
# In tests, this should point to your local backend or a test server.
VITE_API_URL=http://localhost:8080

# n8n webhook URLs (mocked in tests; set these if running e2e)
VITE_N8N_BIENVENIDA_URL=http://localhost:5678/webhook/bienvenida
VITE_N8N_CARRITO_ABANDONADO_URL=http://localhost:5678/webhook/carrito-abandonado
VITE_N8N_COMPRA_EXITOSA_URL=http://localhost:5678/webhook/compra-exitosa
VITE_N8N_COMPRA_FALLIDA_URL=http://localhost:5678/webhook/compra-fallida
